<Application x:Class="CodexBarWindows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:vw="clr-namespace:CodexBarWindows.Views"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ContextMenu x:Key="SysTrayMenu">
            <MenuItem Header="Settings" Command="{Binding ShowSettingsCommand}" />
            <Separator />
            <MenuItem Header="Quit" Command="{Binding ExitApplicationCommand}" />
        </ContextMenu>

        <tb:TaskbarIcon x:Key="NotifyIcon"
                        ToolTipText="{Binding TooltipText}"
                        ContextMenu="{StaticResource SysTrayMenu}">
            <tb:TaskbarIcon.TrayPopup>
                <vw:TrayPopup />
            </tb:TaskbarIcon.TrayPopup>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
