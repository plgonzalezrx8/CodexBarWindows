<Window x:Class="CodexBarWindows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CodexBarWindows.ViewModels"
        Title="CodexBar Settings"
        Width="560" Height="520"
        MinWidth="480" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- ── Accent colors ────────────────────── -->
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="PanelBg" Color="#252536"/>
        <SolidColorBrush x:Key="CardBg" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#383850"/>
        <SolidColorBrush x:Key="FgPrimary" Color="#E4E4EF"/>
        <SolidColorBrush x:Key="FgSecondary" Color="#9090A8"/>
        <SolidColorBrush x:Key="FgMuted" Color="#6B6B80"/>
        <SolidColorBrush x:Key="ToggleOnBg" Color="#7C3AED"/>
        <SolidColorBrush x:Key="ToggleOffBg" Color="#3B3B50"/>

        <!-- ── TabItem style (vertical sidebar) ─── -->
        <Style x:Key="SidebarTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                Margin="4,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#33335A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle switch style ──────────────── -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="40" Height="22">
                                <Border x:Name="Track" CornerRadius="11"
                                        Background="{StaticResource ToggleOffBg}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="2" Opacity="0.2"/>
                                    </Border.Effect>
                                </Border>
                                <Ellipse x:Name="Thumb" Width="16" Height="16"
                                         Fill="White" HorizontalAlignment="Left"
                                         Margin="3,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Grid>
                            <ContentPresenter x:Name="Cp" Margin="10,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource ToggleOnBg}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section header style ─────────────── -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FgMuted}"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>

        <!-- ── Setting row style ────────────────── -->
        <Style x:Key="SettingRow" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- ── ComboBox dark style ──────────────── -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ── Button styles ────────────────────── -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#353548"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════ SIDEBAR ════════════════════════════ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,18,16,10">
                    <TextBlock Text="CodexBar" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FgPrimary}"/>
                    <TextBlock Text="Settings" FontSize="12"
                               Foreground="{StaticResource FgMuted}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Tab headers -->
                <TabControl x:Name="MainTabs" TabStripPlacement="Left"
                            Background="Transparent" BorderThickness="0"
                            Margin="0,8,0,0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem" BasedOn="{StaticResource SidebarTab}"/>
                    </TabControl.Resources>

                    <!-- ────── PROVIDERS TAB ──────── -->
                    <TabItem Header="⚡  Providers">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="PROVIDER TOGGLES" Style="{StaticResource SectionLabel}"/>

                                <ItemsControl ItemsSource="{Binding Providers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SettingRow}">
                                                <DockPanel>
                                                    <CheckBox DockPanel.Dock="Right"
                                                              Style="{StaticResource ToggleSwitch}"
                                                              IsChecked="{Binding IsEnabled}"/>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding ProviderName}"
                                                                   Foreground="{StaticResource FgPrimary}"
                                                                   FontSize="13" FontWeight="Medium"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ────── GENERAL TAB ────────── -->
                    <TabItem Header="⚙  General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="REFRESH" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <ComboBox DockPanel.Dock="Right" Width="90"
                                                  Style="{StaticResource DarkCombo}"
                                                  SelectedIndex="{Binding RefreshIntervalIndex}">
                                            <ComboBoxItem Content="Manual"/>
                                            <ComboBoxItem Content="1 min"/>
                                            <ComboBoxItem Content="2 min"/>
                                            <ComboBoxItem Content="5 min"/>
                                            <ComboBoxItem Content="15 min"/>
                                        </ComboBox>
                                        <TextBlock Text="Refresh interval"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding EnableStatusChecks}"/>
                                        <TextBlock Text="Enable status checks"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding EnableSessionNotifications}"/>
                                        <TextBlock Text="Session notifications"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding ShowCostSummary}"/>
                                        <TextBlock Text="Show cost summary"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="STARTUP" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding RunAtStartup}"/>
                                        <TextBlock Text="Launch at login"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ────── DISPLAY TAB ───────── -->
                    <TabItem Header="🎨  Display">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="ICON" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding MergeIcons}"/>
                                        <TextBlock Text="Merge provider icons"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding SwitcherShowsIcons}"/>
                                        <TextBlock Text="Switcher shows provider icons"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding MenuBarShowsPercent}"/>
                                        <TextBlock Text="Show percent in tray"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="USAGE FORMAT" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <ComboBox DockPanel.Dock="Right" Width="100"
                                                  Style="{StaticResource DarkCombo}"
                                                  SelectedIndex="{Binding DisplayModeIndex}">
                                            <ComboBoxItem Content="Standard"/>
                                            <ComboBoxItem Content="Pace"/>
                                        </ComboBox>
                                        <TextBlock Text="Display mode"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding ShowUsageAsUsed}"/>
                                        <TextBlock Text="Show usage as 'used' (vs remaining)"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding ShowResetTimeAsClock}"/>
                                        <TextBlock Text="Show reset time as clock"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding ShowCredits}"/>
                                        <TextBlock Text="Show credits"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ────── ADVANCED TAB ──────── -->
                    <TabItem Header="🔧  Advanced">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="PRIVACY" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding HidePersonalInfo}"/>
                                        <TextBlock Text="Hide personal info"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding DisableCredentialAccess}"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Disable credential access"
                                                       Foreground="{StaticResource FgPrimary}" FontSize="13"/>
                                            <TextBlock Text="Prevents reading browser cookies"
                                                       Foreground="{StaticResource FgMuted}" FontSize="11"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="DEBUG" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding ShowDebugSettings}"/>
                                        <TextBlock Text="Show debug settings"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Right" Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding SurpriseMe}"/>
                                        <TextBlock Text="Surprise me ✨"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="KEYBOARD" Style="{StaticResource SectionLabel}"/>
                                <Border Style="{StaticResource SettingRow}">
                                    <DockPanel>
                                        <TextBox DockPanel.Dock="Right" Width="120"
                                                 Background="{StaticResource CardBg}"
                                                 Foreground="{StaticResource FgPrimary}"
                                                 BorderBrush="{StaticResource BorderBrush}"
                                                 Padding="6,4" FontSize="12"
                                                 Text="{Binding GlobalShortcut, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="Global shortcut"
                                                   Foreground="{StaticResource FgPrimary}"
                                                   VerticalAlignment="Center" FontSize="13"/>
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="DANGER ZONE" Style="{StaticResource SectionLabel}"
                                           Foreground="#EF4444" Margin="0,20,0,6"/>
                                <Button Content="Reset All Settings" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding ResetDefaultsCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ────── ABOUT TAB ─────────── -->
                    <TabItem Header="ℹ  About">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="CodexBar for Windows" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource FgPrimary}" Margin="0,0,0,4"/>
                                <TextBlock Foreground="{StaticResource FgSecondary}" FontSize="13"
                                           Margin="0,0,0,16">
                                    <Run Text="Version "/>
                                    <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                </TextBlock>

                                <Border Style="{StaticResource SettingRow}" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="Settings file" Foreground="{StaticResource FgMuted}" FontSize="11"/>
                                        <TextBlock Text="{Binding SettingsFilePath, Mode=OneWay}"
                                                   Foreground="{StaticResource FgSecondary}" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SettingRow}" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock Text="Technology" Foreground="{StaticResource FgMuted}" FontSize="11"/>
                                        <TextBlock Text=".NET 9 · WPF · Hardcodet NotifyIcon"
                                                   Foreground="{StaticResource FgSecondary}" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="A system tray utility for monitoring AI coding tool usage."
                                           Foreground="{StaticResource FgMuted}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,12,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>

        <!-- ════ BOTTOM BAR (spans full width over content) ════ -->
        <Border Grid.Column="1" VerticalAlignment="Bottom"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Save" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"/>
                <TextBlock Text="Changes are applied on save"
                           Foreground="{StaticResource FgMuted}" FontSize="11"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
